---
const {
  guide,
  forYou,
  inClass,
  symbol,
  crosses = [],
  activities = [],
} = Astro.props;
---

<div class="study-grid study-grid--student">
  <article class="study-card study-card--large">
    <p class="eyebrow">Domanda grande</p>
    <h2>{guide}</h2>
  </article>
  {forYou && (
    <article class="study-card">
      <p class="eyebrow">Domanda per te</p>
      <h3>{forYou}</h3>
    </article>
  )}
  {inClass && (
    <article class="study-card">
      <p class="eyebrow">In classe succede questo</p>
      <p>{inClass}</p>
    </article>
  )}
  {symbol && (
    <article class="study-card symbol-card">
      <p class="eyebrow">Simbolo</p>
      <h3>{symbol}</h3>
    </article>
  )}
  <article class="study-card">
    <p class="eyebrow">Cosa attraversiamo</p>
    <ul>
      {crosses.map((item: string) => <li>{item}</li>)}
    </ul>
  </article>
  <article class="study-card">
    <p class="eyebrow">Attività reali</p>
    <ul>
      {activities.map((item: string) => <li>{item}</li>)}
    </ul>
  </article>
</div>
