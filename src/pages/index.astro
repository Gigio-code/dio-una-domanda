---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import QuestionDeck from "../components/QuestionDeck";
import { methods, paths, site, years } from "../data/site";
---

<BaseLayout title={site.title} description={site.description}>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <Logo />
        <p class="subtitle">{site.subtitle}</p>
        <h1>Dio non è solo una parola religiosa.</h1>
        <p class="lead">
          È una domanda che attraversa il mito, la storia, la filosofia, il
          corpo, la libertà, la morte e il futuro.
        </p>
        <p>
          Questo sito raccoglie il percorso di religione nei cinque anni del
          liceo: non per dare risposte facili, ma per imparare a fare domande
          più vere.
        </p>
        <div class="hero-actions">
          <a class="button" href="/i-cinque-anni">Esplora i cinque anni</a>
          <a class="text-link" href="/la-domanda">Comincia dalla domanda</a>
        </div>
      </div>
      <div class="hero-mark" aria-hidden="true">
        <span>?</span>
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <p class="eyebrow">I cinque percorsi tematici</p>
      <h2>Una ricerca che cresce anno dopo anno</h2>
    </div>
    <div class="path-grid">
      {paths.map((path) => (
        <a class="path-card" href={path.href}>
          <p class="eyebrow">{path.kicker}</p>
          <h3>{path.title}</h3>
          <p>{path.body}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-band">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Come cerchiamo</p>
        <h2>Domande serie, senza paura</h2>
        <p>
          Qui religione non significa imparare risposte già pronte. Significa
          guardare il mondo, ascoltare idee diverse, discutere senza paura e
          capire un po' meglio che persona stai diventando.
        </p>
      </div>
      <div class="method-grid">
        {methods.map((method) => (
          <article>
            <h3>{method.title}</h3>
            <p>{method.body}</p>
          </article>
        ))}
      </div>
      <QuestionDeck client:load />
    </div>
  </section>

  <section class="section shell split">
    <div>
      <p class="eyebrow">Area riservata</p>
      <h2>Materiali per le classi, senza dati personali</h2>
      <p>
        La prima area classi nasce con prudenza: niente voti, niente foto di
        minori, niente elaborati personali identificabili. Solo materiali
        didattici e percorsi.
      </p>
      <a class="button" href="/area-riservata">Vai all'area riservata</a>
    </div>
    <div class="mini-timeline">
      {years.map((year) => (
        <article>
          <strong>{year.year}</strong>
          <span>{year.title}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="closing shell">
    <p class="eyebrow">La domanda resta aperta</p>
    <h2>Che cosa sto diventando mentre cerco una risposta?</h2>
    <a class="text-link" href="/la-domanda-resta-aperta">Leggi la pagina finale</a>
  </section>
</BaseLayout>
