---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import QuestionDeck from "../components/QuestionDeck";
import { methods, paths, site, years } from "../data/site";
---

<BaseLayout title={site.title} description={site.description}>
  <section class="hero">
    <div class="shell hero-grid">
      <Logo />
      <div class="hero-copy">
        <p class="subtitle">Religione, filosofia, futuro</p>
        <h1>Dio: risposta pronta o domanda scomoda?</h1>
        <p class="lead">
          Un percorso per capire cosa cerchiamo quando parliamo di senso,
          paura, libertà e futuro.
        </p>
        <div class="hero-actions" aria-label="Azioni principali">
          <a class="button" href="/la-domanda">Inizia da una domanda</a>
          <a class="text-link" href="/i-cinque-anni">Vedi i percorsi</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <p class="eyebrow">Cinque porte</p>
      <h2>Scegli da dove entrare.</h2>
    </div>
    <div class="path-grid">
      {paths.map((path) => (
        <a class="path-card" href={path.href}>
          <p class="eyebrow">{path.kicker}</p>
          <h3>{path.title}</h3>
          <p>{path.body}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-band">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Come cerchiamo</p>
        <h2>Non impariamo risposte. Alleniamo domande.</h2>
      </div>
      <div class="method-grid">
        {methods.map((method) => (
          <article>
            <h3>{method.title}</h3>
            <p>{method.body}</p>
          </article>
        ))}
      </div>
      <QuestionDeck client:load />
    </div>
  </section>

  <section class="section shell split">
    <div>
      <p class="eyebrow">Area riservata</p>
      <h2>Materiali per lavorare in classe.</h2>
      <p>
        Solo percorsi e schede. Niente voti, foto o dati personali.
      </p>
      <a class="button" href="/area-riservata">Vai all'area riservata</a>
    </div>
    <div class="mini-timeline">
      {years.map((year) => (
        <article>
          <strong>{year.year}</strong>
          <span>{year.title}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="closing shell">
    <p class="eyebrow">La domanda resta aperta</p>
    <h2>Che cosa sto diventando mentre cerco una risposta?</h2>
    <a class="text-link" href="/la-domanda-resta-aperta">Leggi la pagina finale</a>
  </section>
</BaseLayout>
