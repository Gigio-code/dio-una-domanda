---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import QuestionDeck from "../components/QuestionDeck";
import { methods, paths, site, studentVoices, years } from "../data/site";
---

<BaseLayout title={site.title} description={site.description}>
  <section class="hero">
    <div class="shell hero-grid">
      <Logo />
      <div class="hero-copy">
        <h1>Dio: risposta pronta o domanda scomoda?</h1>
        <p class="lead">
          Questo sito non ti dice cosa credere. Ti aiuta a capire che cosa stai cercando.
        </p>
        <div class="manifesto-lines" aria-label="Manifesto del percorso">
          <p>Non devi uscire con una risposta pronta.</p>
          <p>Ma con domande più vere.</p>
          <p>E con almeno una domanda che è davvero tua.</p>
        </div>
        <div class="hero-actions" aria-label="Azioni principali">
          <a class="button" href="/la-domanda">Inizia da una domanda</a>
          <a class="text-link" href="/i-cinque-anni">Vedi il viaggio dei cinque anni</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section shell feature-strip" aria-label="Come funziona">
    <article>
      <p class="eyebrow">Come funziona</p>
      <h2>Non una lezione su cosa credere. Una domanda che ti riguarda.</h2>
    </article>
    <article>
      <p>Si parte da film, immagini, scene quotidiane, domande anonime, casi reali e discussioni.</p>
    </article>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <p class="eyebrow">Cinque porte</p>
      <h2>Scegli da dove entrare.</h2>
    </div>
    <div class="path-grid">
      {paths.map((path) => (
        <a class="path-card" href={path.href}>
          <p class="eyebrow">{path.kicker}</p>
          <h3>{path.title}</h3>
          <p>{path.body}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-band">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Come cerchiamo</p>
        <h2>Non impariamo risposte. Alleniamo domande.</h2>
      </div>
      <div class="method-grid">
        {methods.map((method) => (
          <article>
            <h3>{method.title}</h3>
            <p>{method.body}</p>
          </article>
        ))}
      </div>
      <QuestionDeck client:load />
    </div>
  </section>

  <section class="section shell split">
    <div>
      <p class="eyebrow">Detto da voi</p>
      <h2>Qui dentro potresti esserci anche tu.</h2>
      <p>
        Domande e frasi anonime raccolte in classe: nessun nome, nessuna etichetta, solo tracce vere di ricerca.
      </p>
    </div>
    <div class="student-voice-grid">
      {studentVoices.map((voice) => (
        <blockquote class="student-voice">"{voice}"</blockquote>
      ))}
    </div>
  </section>

  <section class="section shell split">
    <div>
      <p class="eyebrow">Materiali per la classe</p>
      <h2>Schede, immagini, attività brevi.</h2>
      <p>
        L'area contiene materiali didattici non sensibili: niente voti, foto o dati personali.
      </p>
      <a class="button" href="/area-riservata">Guarda cosa c'è dentro</a>
    </div>
    <div class="mini-timeline">
      {years.map((year) => (
        <article>
          <strong>{year.year}</strong>
          <span>{year.title}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="closing shell">
    <p class="eyebrow">La domanda resta aperta</p>
    <h2>Che cosa sto diventando mentre cerco una risposta?</h2>
    <a class="text-link" href="/la-domanda-resta-aperta">Leggi la pagina finale</a>
  </section>
</BaseLayout>
