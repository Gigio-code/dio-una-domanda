---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "La domanda";
const description = "Dio come parola, immagine, desiderio, paura. Non una risposta pronta: una domanda che ti appartiene.";

const paroleDio = [
  "SPERANZA", "RISPOSTA", "FEDE", "AMORE", "INVENZIONE",
  "LUCE", "LUCE", "LUCE", "SOLE", "PERDONO",
  "MIRACOLI", "VITA", "PRESENTE", "CREATORE", "PROTETTORE",
];

const domandeDifficili = [
  {
    domanda: "Chi ha inventato gli dei?",
    piste: [
      "Forse gli uomini, quando non capivano il mondo.",
      "La paura del buio, sinceramente.",
      "Non è come inventare un gioco: è più complicato.",
      "Gli uomini, ma non per forza per mentire.",
      "La domanda: perché esistiamo? Da lì parte tutto.",
      "Secondo me gli dei sono nati dalla meraviglia.",
    ],
  },
  {
    domanda: "Se Dio ha creato noi, chi ha creato Dio?",
    piste: [
      "Bella domanda, questa manda in crash il cervello.",
      "Forse Dio non è stato creato, per definizione.",
      "Non lo so, ma è la domanda più difficile del mondo.",
      "Forse siamo noi che pensiamo sempre in inizio e fine.",
      "È come chiedere cosa c'era prima del prima.",
      "Per la fede: nessuno. Per un ateo: gli uomini.",
    ],
  },
  {
    domanda: "Come si sceglie la propria religione?",
    piste: [
      "Quella che ti fa sentire più vero, non più obbligato.",
      "Non sceglierei come un gusto di gelato, però un po' sì.",
      "La più affine è quella che non senti finta per te.",
      "Forse non si sceglie: ci si nasce dentro e poi si decide.",
      "Quella che ti aiuta a essere una persona migliore.",
    ],
  },
];

const tipologieDio = [
  {
    tipo: "Il Dio dell'ordine",
    descrizione: "Punta sulla giustizia. Punisce, ma non per sadismo: vuole rimettere le cose a posto. È la frustrazione di chi vede un mondo disordinato.",
    domanda: "Se potessi dare una sola legge al mondo, quale sarebbe?",
  },
  {
    tipo: "Il Dio empatico",
    descrizione: "Chiede amore, rispetto, verità. Non obbedienza. Vuole essere capito, non temuto. Spesso si descrive 'come sono ora': non vuole smettere di essere umano.",
    domanda: "Un Dio che capisce tutto di te — ti farebbe sentire libero o sorvegliato?",
  },
  {
    tipo: "Il Dio libertario",
    descrizione: "Non vuole governare, vuole liberare. 'Hanno il libero arbitrio. Scelgono loro.' È il Dio che non interviene — e a volte ne sente la malinconia.",
    domanda: "Un Dio che non interviene mai: è assente o rispettoso?",
  },
  {
    tipo: "Il Dio della natura",
    descrizione: "Protegge gli animali, cura il pianeta. 'Farei riposare la Terra sterilizzando gli uomini.' Voce ecologica, a volte dura, sempre autentica.",
    domanda: "Se la Terra potesse parlare, cosa chiederebbe a Dio?",
  },
  {
    tipo: "Il Dio incarnato",
    descrizione: "Quasi tutti scenderebbero tra gli uomini. Non per dominare, ma per vedere, capire, aiutare. Dei che vogliono guardare negli occhi le persone.",
    domanda: "Se Dio venisse a scuola per un giorno, cosa noterebbe?",
  },
];

const immaginiAldila = [
  { titolo: "Insieme", testo: "Dopo la morte ognuno vive un'altra vita con chi ama, e in felicità." },
  { titolo: "Altrove", testo: "Non inferno o paradiso: un mondo ultraterreno dove le anime osservano le attività umane. Oppure la reincarnazione." },
  { titolo: "Nulla", testo: "Il nulla. Un buio nerissimo, senza niente dentro. L'anima sta qui finché non si reincarna." },
  { titolo: "Luce", testo: "Uno spazio indefinito, luminoso e candido dove l'anima galleggia in questo nulla che non si può immaginare come concreto." },
  { titolo: "Stato", testo: "L'aldilà è uno stato dell'essere: luce, serenità, vuoto, energia, totalità. Non un luogo." },
  { titolo: "Ritorno", testo: "Riviviamo la nostra vita in un lasso di tempo millesimale, riapprezzando le cose viste dall'esterno, perdonando chi non siamo riusciti a perdonare." },
  { titolo: "Domenica", testo: "Il paradiso per questa classe è la domenica insieme, non l'eternità solitaria." },
];
---

<BaseLayout title={title} description={description}>
  <section class="question-hero">
    <p class="section-kicker">La domanda</p>
    <h1>Dio come parola difficile</h1>
    <p class="hero-copy">
      Non una definizione. Non una risposta già pronta.<br />
      Una parola che ognuno porta diversa — e che vale la pena guardare da vicino.
    </p>
  </section>

  <section class="question-section">
    <p class="section-kicker">Da dove siamo partiti</p>
    <h2>Dio con una parola</h2>
    <p class="body-copy">
      Il primo giorno di scuola abbiamo chiesto a tutti la stessa cosa:
      <em>descrivi Dio con una sola parola.</em>
      Nessuna risposta giusta. Nessuna risposta sbagliata.
      Queste sono le parole di una classe prima.
    </p>

    <div class="word-cloud" aria-label="Parole su Dio raccolte in classe prima">
      {paroleDio.map((parola) => <span class="word-chip">{parola}</span>)}
    </div>

    <p class="source-note">Classe prima, settembre 2025. Risposte anonime e aggregate.</p>

    <blockquote class="student-note">
      <p>
        INVENZIONE era una parola sola, ma ha cambiato tutta la conversazione.
        Qualcuno stava dicendo: <em>forse Dio ce lo siamo costruiti noi.</em>
        E da lì è cominciato tutto.
      </p>
    </blockquote>

    <div class="visitor-question">
      <p>Quale parola sceglieresti tu?</p>
      <span>Non devi saperlo già. Puoi anche scegliere: non lo so.</span>
    </div>
  </section>

  <section class="question-section section-band">
    <div class="section-inner">
      <p class="section-kicker">Domande che restano</p>
      <h2>Le domande difficili</h2>
      <p class="body-copy">
        Alcune domande su Dio non hanno risposta certa.
        Ecco cosa ha detto una classe prima quando gliele abbiamo poste.
        Nessun nome. Solo pensieri.
      </p>

      <div class="question-accordion">
        {domandeDifficili.map((item) => (
          <details class="accordion-item">
            <summary>{item.domanda}</summary>
            <ul>
              {item.piste.map((pista) => <li>"{pista}"</li>)}
            </ul>
          </details>
        ))}
      </div>

      <div class="visitor-question">
        <p>C'è una domanda su Dio che non riesci a chiudere?</p>
      </div>
    </div>
  </section>

  <section class="question-section">
    <p class="section-kicker">Un esercizio di quarta</p>
    <h2>Se io fossi Dio</h2>
    <p class="body-copy">
      Abbiamo chiesto a una classe quarta di immaginare di essere una divinità.
      Quali leggi darebbero? Come si descriverebbero?
      Dal loro Olimpo sono emersi cinque tipi di Dio. Riconosci qualcuno?
    </p>

    <div class="god-grid">
      {tipologieDio.map((tipo) => (
        <article class="god-card">
          <h3>{tipo.tipo}</h3>
          <p>{tipo.descrizione}</p>
          <strong>{tipo.domanda}</strong>
        </article>
      ))}
    </div>

    <blockquote class="student-note large-note">
      <p>
        Nel cielo della 4IP non c'è un Dio unico.<br />
        C'è una costellazione di dei adolescenti —<br />
        arrabbiati, dolci, ironici, delusi,<br />
        ma tutti profondamente vivi.
      </p>
    </blockquote>
  </section>

  <section class="question-section section-band">
    <div class="section-inner">
      <p class="section-kicker">Una domanda di quinta</p>
      <h2>Come immagini il dopo?</h2>
      <p class="body-copy">
        Nessuna religione ha la risposta definitiva sull'aldilà.
        Abbiamo chiesto a una classe quinta di scrivere la propria.
        Questi sono alcuni dei loro testi.
      </p>

      <div class="afterlife-list">
        {immaginiAldila.map((voce) => (
          <article class="afterlife-item">
            <h3>{voce.titolo}</h3>
            <p>{voce.testo}</p>
          </article>
        ))}
      </div>

      <p class="source-note">Classe quinta, novembre 2025. Testi scritti dagli studenti, anonimi e aggregati.</p>

      <div class="visitor-question">
        <p>E tu, come lo immagini?</p>
      </div>
    </div>
  </section>

  <section class="question-section guide-section">
    <p class="section-kicker">Domanda guida</p>
    <h2>Dio è una parola che chiude il discorso o apre una ricerca?</h2>
    <div class="guide-questions">
      <p>Che cosa ti viene in mente quando senti la parola Dio?</p>
      <p>Dio è una risposta o una domanda?</p>
      <p>Si può cercare Dio anche senza sapere se ci si crede?</p>
    </div>
  </section>

  <section class="question-section submit-section">
    <p class="section-kicker">Lascia una traccia</p>
    <h2>La tua domanda su Dio</h2>
    <p class="body-copy">
      Questa funzione sarà attivata solo dopo aver configurato raccolta, moderazione
      e privacy in modo corretto. Per ora resta una promessa di metodo: non raccogliere
      dati prima di sapere come custodirli.
    </p>

    <div class="disabled-form" aria-label="Modulo non ancora attivo">
      <label for="domanda-testo">La domanda che non riesco a chiudere è...</label>
      <textarea id="domanda-testo" rows="4" maxlength="300" disabled></textarea>
      <p>Nessun invio è attivo in questa versione pubblica.</p>
      <button type="button" disabled>Invio non ancora attivo</button>
    </div>
  </section>
</BaseLayout>

<style>
  .question-hero,
  .question-section {
    margin: 0 auto;
    max-width: 760px;
    padding: 5rem 1.5rem;
  }

  .question-hero {
    padding-top: 6rem;
    text-align: center;
  }

  .section-band {
    background: var(--bg-soft);
    max-width: none;
    padding-left: 0;
    padding-right: 0;
  }

  .section-inner {
    margin: 0 auto;
    max-width: 760px;
    padding: 0 1.5rem;
  }

  .section-kicker {
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    margin: 0 0 0.85rem;
    text-transform: uppercase;
  }

  h1, h2, h3 {
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2.2rem, 7vw, 4.2rem);
    line-height: 1.02;
    margin: 0 0 1.25rem;
  }

  h2 {
    font-size: clamp(1.55rem, 4vw, 2.35rem);
    line-height: 1.12;
    margin: 0 0 1.35rem;
  }

  h3 {
    font-size: 1.05rem;
    margin: 0 0 0.65rem;
  }

  .hero-copy, .body-copy {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 1.5rem;
  }

  .hero-copy { font-size: 1.1rem; }

  .word-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 2rem 0;
  }

  .word-chip {
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    padding: 0.45rem 0.75rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .word-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .source-note {
    color: var(--muted);
    font-size: 0.82rem;
    font-style: italic;
    line-height: 1.5;
    margin: 1rem 0 0;
  }

  .student-note {
    background: rgba(246, 237, 219, 0.035);
    border-left: 2px solid var(--accent);
    border-radius: 0 6px 6px 0;
    margin: 2rem 0;
    padding: 1rem 1.35rem;
  }

  .student-note p {
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  .large-note {
    border-left: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    text-align: center;
  }

  .visitor-question {
    border: 1px solid var(--accent);
    border-radius: 6px;
    margin-top: 2.25rem;
    padding: 1.25rem;
    text-align: center;
  }

  .visitor-question p {
    color: var(--cream);
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.45;
    margin: 0;
  }

  .visitor-question span {
    color: var(--muted);
    display: block;
    font-size: 0.9rem;
    margin-top: 0.45rem;
  }

  .question-accordion {
    display: grid;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .accordion-item {
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
  }

  .accordion-item summary {
    color: var(--cream);
    cursor: pointer;
    font-family: var(--font-body);
    list-style: none;
    padding: 1rem 1.15rem;
  }

  .accordion-item summary::-webkit-details-marker { display: none; }
  .accordion-item summary::after { color: var(--accent); content: "+"; float: right; }
  .accordion-item[open] summary::after { content: "-"; }

  .accordion-item ul {
    border-top: 1px solid var(--line);
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 1rem 1.15rem 1.2rem;
  }

  .accordion-item li {
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 0.94rem;
    font-style: italic;
    line-height: 1.65;
    padding-left: 0.75rem;
    border-left: 1px solid var(--line);
  }

  .god-grid, .afterlife-list {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .god-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }

  .god-card, .afterlife-item {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 1.15rem;
    transition: border-color 0.2s;
  }

  .god-card:hover, .afterlife-item:hover { border-color: var(--accent); }

  .god-card p, .afterlife-item p {
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.65;
    margin: 0;
  }

  .god-card strong {
    color: var(--accent);
    display: block;
    font-size: 0.9rem;
    font-style: italic;
    font-weight: 500;
    line-height: 1.5;
    margin-top: 0.9rem;
  }

  .afterlife-item { display: grid; gap: 0.25rem; }

  .guide-section { text-align: center; }

  .guide-questions {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .guide-questions p {
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.55;
    margin: 0;
  }

  .submit-section { border-top: 1px solid var(--line); }

  .disabled-form {
    display: grid;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .disabled-form label, .disabled-form p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .disabled-form textarea {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--cream);
    font: inherit;
    padding: 0.85rem;
    resize: vertical;
  }

  .disabled-form button {
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--muted);
    justify-self: start;
    padding: 0.65rem 1rem;
  }

  @media (max-width: 640px) {
    .question-hero, .question-section { padding: 3.5rem 1.1rem; }
    .section-inner { padding: 0 1.1rem; }
    .disabled-form button { justify-self: stretch; }
  }
</style>
