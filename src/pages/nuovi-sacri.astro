---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import StudyBlocks from "../components/StudyBlocks.astro";
import SubpageNav from "../components/SubpageNav.astro";
import { publicPages } from "../data/site";

const page = publicPages.nuoviSacri;
---

<BaseLayout title={page.eyebrow} description={page.intro}>
  <PageHero eyebrow={page.eyebrow} title={page.title} intro={page.intro} />
  <section class="section shell">
    <StudyBlocks guide={page.guide} forYou={page.forYou} inClass={page.inClass} symbol={page.symbol} crosses={page.crosses} activities={page.activities} cards={page.cards} archive={page.archive} />
    <div class="question-list question-list--voice">
      {page.questions.map((question) => <article>{question}</article>)}
    </div>
  </section>
  <SubpageNav pages={[
    { href: "/nuovi-sacri/crisi-degli-dei-morte-destino/", title: "Crisi degli dei, morte, destino", kicker: "Serie" },
    { href: "/nuovi-sacri/ia-relazione/", title: "IA e relazione", kicker: "Scenario" },
    { href: "/nuovi-sacri/homo-deus-datismo/", title: "Homo Deus e datismo", kicker: "Scelta critica" },
    { href: "/nuovi-sacri/palantir-protezione-anticristo/", title: "Palantir, protezione, Anticristo", kicker: "Dilemma" },
    { href: "/nuovi-sacri/corpo-perfetto-uglies/", title: "Corpo perfetto: Uglies", kicker: "Laboratorio" },
    { href: "/nuovi-sacri/religione-politica-potere/", title: "Religione, politica, potere", kicker: "Lettere" },
  ]} />
</BaseLayout>
