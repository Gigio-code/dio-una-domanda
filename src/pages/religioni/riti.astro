---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const title = "Riti";
const description = "Contenuto in costruzione. Questa pagina farà parte del percorso «DIO. UNA DOMANDA» e sarà completata con materiali, attività e domande per gli studenti.";
---

<BaseLayout title={title} description={description}>
  <PageHero eyebrow="Religioni" title={title} intro={description} />
  <section class="section shell">
    <p class="lead">Contenuto in costruzione.</p>
  </section>
</BaseLayout>
